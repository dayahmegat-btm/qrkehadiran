APP_NAME="e-DAFTAR Kedah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ms
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ms_MY

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edaftar_kedah
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=edaftar

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@kedah.gov.my"
MAIL_FROM_NAME="${APP_NAME}"

# File Storage (MinIO/S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# EPSM API Configuration
EPSM_API_URL=https://epsm.kedah.gov.my/api_kuarters.php
EPSM_API_SECRET_KEY=DigitalPKN2021
EPSM_API_TIMEOUT=10
EPSM_API_CACHE_MINUTES=60
EPSM_API_RATE_LIMIT=60

# QR Code Settings
QR_STATIC_EXPIRY_HOURS=2
QR_DYNAMIC_EXPIRY_SECONDS=30

# Geolocation Settings
GEO_DEFAULT_RADIUS_METERS=100
GEO_MAX_RADIUS_METERS=1000

# Certificate Settings
CERT_TEMPLATE_PATH=resources/views/certificates
CERT_STORAGE_DISK=s3
CERT_VERIFICATION_URL="${APP_URL}/verify"

# Training Hours Settings
TRAINING_HOURS_TARGET_ANNUAL=56

# Notification Settings
NOTIF_EVENT_REMINDER_DAYS=7,1
NOTIF_EVENT_REMINDER_HOURS=1
